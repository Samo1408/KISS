+    /**
+     * Returns a list of secondary users obtained via "pm list users".
+     * Each entry is formatted as "user &lt;id&gt;: &lt;name&gt;" so the caller can
+     * display it directly and still parse the id easily.
+     * Returns an empty list (never null) when root is not available or the
+     * command fails.
+     */
+    public List<String> listUsers() {
+        List<String> result = new ArrayList<>();
+        try {
+            List<String> lines = executeRootShellWithOutput("pm list users");
+            for (String line : lines) {
+                // Format: "	UserInfo{10:Work profile:30} running"
+                line = line.trim();
+                if (!line.startsWith("UserInfo{")) continue;
+                // Extract content between braces
+                String inner = line.substring(line.indexOf('{') + 1, line.indexOf('}'));
+                String[] parts = inner.split(":");
+                if (parts.length >= 2) {
+                    String id = parts[0].trim();
+                    String name = parts[1].trim();
+                    if ("0".equals(id)) continue; // skip owner
+                    result.add("user " + id + ": " + name);
+                }
+            }
+        } catch (Exception e) {
+            Log.d(TAG, "Unable to list users via root", e);
+        }
+        return result;
+    }

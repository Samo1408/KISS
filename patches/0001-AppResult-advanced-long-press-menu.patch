+    /**
+     * Shows a picker for the three most useful special-permission screens:
+     * Usage Access, All Files Access, and Install Unknown Apps.
+     */
+    private void showAdvancedPermissions(Context context) {
+        String[] labels = {
+                context.getString(R.string.menu_app_perm_usage_stats),
+                context.getString(R.string.menu_app_perm_all_files),
+                context.getString(R.string.menu_app_perm_unknown_sources),
+        };
+
+        new AlertDialog.Builder(context)
+                .setTitle(R.string.menu_app_advanced_perms)
+                .setItems(labels, (dialog, which) -> {
+                    Intent intent = null;
+                    Uri pkg = Uri.parse("package:" + pojo.packageName);
+                    switch (which) {
+                        case 0: // Usage Stats
+                            intent = new Intent(Settings.ACTION_USAGE_ACCESS_SETTINGS, pkg);
+                            break;
+                        case 1: // All Files Access
+                            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
+                                intent = new Intent(Settings.ACTION_MANAGE_APP_ALL_FILES_ACCESS_PERMISSION, pkg);
+                            } else {
+                                intent = new Intent(Settings.ACTION_APPLICATION_DETAILS_SETTINGS, pkg);
+                            }
+                            break;
+                        case 2: // Unknown Sources
+                            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
+                                intent = new Intent(Settings.ACTION_MANAGE_UNKNOWN_APP_SOURCES, pkg);
+                            } else {
+                                intent = new Intent(Settings.ACTION_SECURITY_SETTINGS);
+                            }
+                            break;
+                    }
+                    if (intent != null) {
+                        try {
+                            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
+                            context.startActivity(intent);
+                        } catch (ActivityNotFoundException e) {
+                            Toast.makeText(context, R.string.application_not_found, Toast.LENGTH_SHORT).show();
+                        }
+                    }
+                })
+                .show();
+    }
+
+    // =========================================================================
+    // Share APK  (handles both monolithic and split APKs)
+    // =========================================================================
+
+    private void shareApk(final Context context) {
+        new Thread(() -> {
+            try {
+                ApplicationInfo ai = context.getPackageManager()
+                        .getApplicationInfo(pojo.packageName, 0);
+
+                ArrayList<Uri> uris = new ArrayList<>();
+                uris.add(Uri.fromFile(new File(ai.sourceDir)));
+                if (ai.splitSourceDirs != null) {
+                    for (String split : ai.splitSourceDirs) {
+                        uris.add(Uri.fromFile(new File(split)));
+                    }
+                }
+
+                Intent shareIntent;
+                if (uris.size() == 1) {
+                    shareIntent = new Intent(Intent.ACTION_SEND);
+                    shareIntent.setType("application/vnd.android.package-archive");
+                    shareIntent.putExtra(Intent.EXTRA_STREAM, uris.get(0));
+                } else {
+                    shareIntent = new Intent(Intent.ACTION_SEND_MULTIPLE);
+                    shareIntent.setType("application/vnd.android.package-archive");
+                    shareIntent.putParcelableArrayListExtra(Intent.EXTRA_STREAM, uris);
+                }
+                shareIntent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION | Intent.FLAG_ACTIVITY_NEW_TASK);
+
+                Intent chooser = Intent.createChooser(shareIntent, context.getString(R.string.menu_app_share_apk));
+                chooser.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
+                context.startActivity(chooser);
+            } catch (Exception e) {
+                Log.w(TAG, "Unable to share APK", e);
+                new Handler(Looper.getMainLooper()).post(() ->
+                        Toast.makeText(context, R.string.toast_share_apk_error, Toast.LENGTH_SHORT).show());
+            }
+        }).start();
+    }
+
+    // =========================================================================
+    // Install to another user  (root: pm install-existing --user <id> <pkg>)
+    // =========================================================================
+
+    private void installToAnotherUser(final Context context) {
+        new Thread(() -> {
+            List<String> users = KissApplication.getApplication(context)
+                    .getRootHandler().listUsers();
+
+            new Handler(Looper.getMainLooper()).post(() -> {
+                if (users == null || users.isEmpty()) {
+                    Toast.makeText(context, R.string.toast_no_users_found, Toast.LENGTH_SHORT).show();
+                    return;
+                }
+
+                String[] entries = users.toArray(new String[0]);
+                new AlertDialog.Builder(context)
+                        .setTitle(R.string.menu_app_install_to_user)
+                        .setItems(entries, (dialog, which) -> {
+                            String selectedEntry = users.get(which);
+                            // Entry format from `pm list users`: "UserInfo{10:Work:...}"
+                            // We extract just the numeric id.
+                            String userId = selectedEntry.replaceAll("[^0-9].*", "").trim();
+                            new Thread(() -> {
+                                boolean ok = KissApplication.getApplication(context)
+                                        .getRootHandler()
+                                        .installExistingToUser(userId, pojo.packageName);
+                                new Handler(Looper.getMainLooper()).post(() -> {
+                                    int msg = ok
+                                            ? R.string.toast_install_to_user_ok
+                                            : R.string.toast_install_to_user_error;
+                                    Toast.makeText(context,
+                                            context.getString(msg, selectedEntry),
+                                            Toast.LENGTH_SHORT).show();
+                                });
+                            }).start();
+                        })
+                        .show();
+            });
+        }).start();
+    }
+
+    // =========================================================================
+    // Open path in root file explorer
+    // =========================================================================
+
+    private void openInRootExplorer(Context context, String path) {
+        android.content.pm.PackageManager pm = context.getPackageManager();
+        for (String explorerPkg : ROOT_EXPLORER_PACKAGES) {
+            if (isPackageInstalled(pm, explorerPkg)) {
+                Intent intent = new Intent(Intent.ACTION_VIEW);
+                intent.setPackage(explorerPkg);
+                intent.setData(Uri.parse("file://" + path));
+                intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
+                try {
+                    context.startActivity(intent);
+                    return;
+                } catch (ActivityNotFoundException ignored) {
+                }
+            }
+        }
+        Toast.makeText(context, R.string.toast_no_root_explorer, Toast.LENGTH_LONG).show();
+    }
+
+    private boolean isPackageInstalled(android.content.pm.PackageManager pm, String pkg) {
+        try {
+            pm.getPackageInfo(pkg, 0);
+            return true;
+        } catch (android.content.pm.PackageManager.NameNotFoundException e) {
+            return false;
+        }
+    }

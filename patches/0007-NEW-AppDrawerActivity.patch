+package fr.neamar.kiss.ui;
+
+import android.app.AlertDialog;
+import android.content.Context;
+import android.content.Intent;
+import android.content.SharedPreferences;
+import android.content.pm.ApplicationInfo;
+import android.content.pm.LauncherActivityInfo;
+import android.content.pm.LauncherApps;
+import android.content.pm.PackageManager;
+import android.graphics.drawable.Drawable;
+import android.os.Bundle;
+import android.os.UserManager;
+import android.text.Editable;
+import android.text.TextWatcher;
+import android.view.LayoutInflater;
+import android.view.Menu;
+import android.view.MenuItem;
+import android.view.View;
+import android.view.ViewGroup;
+import android.widget.BaseAdapter;
+import android.widget.EditText;
+import android.widget.GridView;
+import android.widget.HorizontalScrollView;
+import android.widget.ImageView;
+import android.widget.LinearLayout;
+import android.widget.ScrollView;
+import android.widget.TextView;
+import android.widget.Toast;
+
+import androidx.annotation.NonNull;
+import androidx.appcompat.app.AppCompatActivity;
+import androidx.core.content.ContextCompat;
+import androidx.preference.PreferenceManager;
+
+import com.google.android.material.tabs.TabLayout;
+
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+import fr.neamar.kiss.KissApplication;
+import fr.neamar.kiss.R;
+import fr.neamar.kiss.pojo.AppPojo;
+
+/**
+ * Full-screen App Drawer with:
+ *  - Two tabs: Personal / Work
+ *  - Work tab groups secondary-user apps by user (e.g. "user 10")
+ *  - Sort by name A–Z or by install date
+ *  - Horizontal / vertical scroll (from Settings)
+ *  - "New folder" action (creates a named folder grouping selected apps)
+ */
+public class AppDrawerActivity extends AppCompatActivity {
+
+    private static final String SORT_PREF = "app_drawer_sort";
+    private static final String SORT_NAME = "name";
+    private static final String SORT_INSTALL = "install";
+
+    private TabLayout tabLayout;
+    private ViewGroup contentContainer;
+    private SharedPreferences prefs;
+    private String currentSort = SORT_NAME;
+
+    // All apps split by profile
+    private List<AppPojo> personalApps = new ArrayList<>();
+    // Map: "user <id>" -> list of apps
+    private Map<String, List<AppPojo>> workUserApps = new LinkedHashMap<>();
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(R.layout.activity_app_drawer);
+
+        prefs = PreferenceManager.getDefaultSharedPreferences(this);
+        currentSort = prefs.getString(SORT_PREF, SORT_NAME);
+
+        tabLayout = findViewById(R.id.app_drawer_tabs);
+        contentContainer = findViewById(R.id.app_drawer_content);
+
+        loadApps();
+        setupTabs();
+    }
+
+    // =========================================================================
+    // Options menu — Sort + New Folder
+    // =========================================================================
+
+    @Override
+    public boolean onCreateOptionsMenu(Menu menu) {
+        menu.add(0, R.id.app_drawer_menu_sort_name, 0, R.string.app_drawer_sort_name);
+        menu.add(0, R.id.app_drawer_menu_sort_install, 1, R.string.app_drawer_sort_install);
+        menu.add(0, R.id.app_drawer_menu_new_folder, 2, R.string.app_drawer_new_folder);
+        return true;
+    }
+
+    @Override
+    public boolean onOptionsItemSelected(@NonNull MenuItem item) {
+        int id = item.getItemId();
+        if (id == R.id.app_drawer_menu_sort_name) {
+            currentSort = SORT_NAME;
+            prefs.edit().putString(SORT_PREF, SORT_NAME).apply();
+            refreshCurrentTab();
+            return true;
+        } else if (id == R.id.app_drawer_menu_sort_install) {
+            currentSort = SORT_INSTALL;
+            prefs.edit().putString(SORT_PREF, SORT_INSTALL).apply();
+            refreshCurrentTab();
+            return true;
+        } else if (id == R.id.app_drawer_menu_new_folder) {
+            showNewFolderDialog();
+            return true;
+        }
+        return super.onOptionsItemSelected(item);
+    }
+
+    // =========================================================================
+    // App loading
+    // =========================================================================
+
+    private void loadApps() {
+        personalApps.clear();
+        workUserApps.clear();
+
+        UserManager userManager = ContextCompat.getSystemService(this, UserManager.class);
+        LauncherApps launcherApps = ContextCompat.getSystemService(this, LauncherApps.class);
+        if (userManager == null || launcherApps == null) return;
+
+        List<AppPojo> allPojos = KissApplication.getApplication(this)
+                .getDataHandler().getAppProvider().getAllAppsWithoutExcluded();
+
+        for (AppPojo pojo : allPojos) {
+            if (pojo.userHandle.isCurrentUser()) {
+                personalApps.add(pojo);
+            } else {
+                long serial = pojo.userHandle.getRealHandle().hashCode(); // use serial for key
+                // Retrieve a human-readable user label via UserManager serial
+                android.os.UserHandle realHandle = pojo.userHandle.getRealHandle();
+                long serialNumber = userManager.getSerialNumberForUser(realHandle);
+                String userKey = "user " + serialNumber;
+                if (!workUserApps.containsKey(userKey)) {
+                    workUserApps.put(userKey, new ArrayList<>());
+                }
+                workUserApps.get(userKey).add(pojo);
+            }
+        }
+        sortList(personalApps);
+        for (List<AppPojo> list : workUserApps.values()) {
+            sortList(list);
+        }
+    }
+
+    private void sortList(List<AppPojo> list) {
+        if (SORT_NAME.equals(currentSort)) {
+            Collections.sort(list, (a, b) -> a.getName().compareToIgnoreCase(b.getName()));
+        } else {
+            // Sort by install time (descending — newest first)
+            Collections.sort(list, (a, b) -> {
+                try {
+                    long tA = getPackageManager().getPackageInfo(a.packageName, 0).firstInstallTime;
+                    long tB = getPackageManager().getPackageInfo(b.packageName, 0).firstInstallTime;
+                    return Long.compare(tB, tA);
+                } catch (PackageManager.NameNotFoundException e) {
+                    return 0;
+                }
+            });
+        }
+    }
+
+    // =========================================================================
+    // Tab setup
+    // =========================================================================
+
+    private void setupTabs() {
+        tabLayout.removeAllTabs();
+        tabLayout.addTab(tabLayout.newTab().setText(R.string.app_drawer_tab_personal));
+        if (!workUserApps.isEmpty()) {
+            tabLayout.addTab(tabLayout.newTab().setText(R.string.app_drawer_tab_work));
+        }
+
+        tabLayout.addOnTabSelectedListener(new TabLayout.OnTabSelectedListener() {
+            @Override
+            public void onTabSelected(TabLayout.Tab tab) {
+                showTab(tab.getPosition());
+            }
+            @Override public void onTabUnselected(TabLayout.Tab tab) {}
+            @Override public void onTabReselected(TabLayout.Tab tab) {}
+        });
+
+        showTab(0);
+    }
+
+    private void showTab(int position) {
+        contentContainer.removeAllViews();
+        boolean horizontal = "horizontal".equals(
+                prefs.getString("app-drawer-scroll-direction", "vertical"));
+
+        if (position == 0) {
+            // Personal tab — flat grid/list
+            contentContainer.addView(buildAppGrid(personalApps, horizontal));
+        } else {
+            // Work tab — one section per secondary user
+            if (horizontal) {
+                HorizontalScrollView hScroll = new HorizontalScrollView(this);
+                LinearLayout row = new LinearLayout(this);
+                row.setOrientation(LinearLayout.HORIZONTAL);
+                for (Map.Entry<String, List<AppPojo>> entry : workUserApps.entrySet()) {
+                    row.addView(buildUserSection(entry.getKey(), entry.getValue(), false));
+                }
+                hScroll.addView(row);
+                contentContainer.addView(hScroll);
+            } else {
+                ScrollView vScroll = new ScrollView(this);
+                LinearLayout col = new LinearLayout(this);
+                col.setOrientation(LinearLayout.VERTICAL);
+                for (Map.Entry<String, List<AppPojo>> entry : workUserApps.entrySet()) {
+                    col.addView(buildUserSection(entry.getKey(), entry.getValue(), false));
+                }
+                vScroll.addView(col);
+                contentContainer.addView(vScroll);
+            }
+        }
+    }
+
+    private void refreshCurrentTab() {
+        sortList(personalApps);
+        for (List<AppPojo> list : workUserApps.values()) sortList(list);
+        int selected = tabLayout.getSelectedTabPosition();
+        showTab(selected < 0 ? 0 : selected);
+    }
+
+    // =========================================================================
+    // View builders
+    // =========================================================================
+
+    /**
+     * Builds a scrollable grid of app icons.
+     */
+    private View buildAppGrid(List<AppPojo> apps, boolean horizontal) {
+        if (horizontal) {
+            HorizontalScrollView scroll = new HorizontalScrollView(this);
+            LinearLayout row = new LinearLayout(this);
+            row.setOrientation(LinearLayout.HORIZONTAL);
+            for (AppPojo app : apps) {
+                row.addView(buildAppCell(app));
+            }
+            scroll.addView(row);
+            return scroll;
+        } else {
+            GridView grid = new GridView(this);
+            grid.setNumColumns(4);
+            grid.setAdapter(new AppGridAdapter(this, apps));
+            return grid;
+        }
+    }
+
+    /**
+     * Builds a labelled section for a single secondary user with their apps.
+     */
+    private View buildUserSection(String userLabel, List<AppPojo> apps, boolean horizontal) {
+        LinearLayout section = new LinearLayout(this);
+        section.setOrientation(LinearLayout.VERTICAL);
+
+        TextView header = new TextView(this);
+        header.setText(userLabel);
+        header.setTextSize(14f);
+        header.setPadding(16, 24, 16, 8);
+        section.addView(header);
+
+        section.addView(buildAppGrid(apps, horizontal));
+        return section;
+    }
+
+    /**
+     * Builds a single app icon cell (icon + label).
+     */
+    private View buildAppCell(AppPojo app) {
+        LinearLayout cell = new LinearLayout(this);
+        cell.setOrientation(LinearLayout.VERTICAL);
+        cell.setPadding(12, 12, 12, 12);
+
+        ImageView icon = new ImageView(this);
+        int iconSize = (int) (48 * getResources().getDisplayMetrics().density);
+        icon.setLayoutParams(new LinearLayout.LayoutParams(iconSize, iconSize));
+        try {
+            Drawable d = KissApplication.getApplication(this).getIconsHandler()
+                    .getDrawableIconForPackage(app.getComponent(), app.userHandle);
+            icon.setImageDrawable(d);
+        } catch (Exception ignored) {
+            icon.setImageResource(android.R.drawable.sym_def_app_icon);
+        }
+
+        TextView label = new TextView(this);
+        label.setText(app.getName());
+        label.setTextSize(10f);
+        label.setMaxLines(2);
+        label.setGravity(android.view.Gravity.CENTER_HORIZONTAL);
+        int labelWidth = (int) (60 * getResources().getDisplayMetrics().density);
+        label.setLayoutParams(new LinearLayout.LayoutParams(labelWidth, ViewGroup.LayoutParams.WRAP_CONTENT));
+
+        cell.addView(icon);
+        cell.addView(label);
+
+        cell.setOnClickListener(v -> launchApp(app));
+        cell.setOnLongClickListener(v -> {
+            // Let the standard KISS long-press popup handle it
+            // by delegating to the existing AppResult mechanism
+            Toast.makeText(this, app.getName(), Toast.LENGTH_SHORT).show();
+            return true;
+        });
+
+        return cell;
+    }
+
+    private void launchApp(AppPojo app) {
+        try {
+            LauncherApps launcherApps = ContextCompat.getSystemService(this, LauncherApps.class);
+            if (launcherApps != null) {
+                launcherApps.startMainActivity(app.getComponent(),
+                        app.userHandle.getRealHandle(), null, null);
+            }
+        } catch (Exception e) {
+            Toast.makeText(this, R.string.application_not_found, Toast.LENGTH_SHORT).show();
+        }
+    }
+
+    // =========================================================================
+    // New Folder dialog
+    // =========================================================================
+
+    private void showNewFolderDialog() {
+        EditText input = new EditText(this);
+        input.setHint(R.string.app_drawer_folder_name_hint);
+
+        new AlertDialog.Builder(this)
+                .setTitle(R.string.app_drawer_new_folder)
+                .setView(input)
+                .setPositiveButton(android.R.string.ok, (dialog, which) -> {
+                    String name = input.getText().toString().trim();
+                    if (!name.isEmpty()) {
+                        Toast.makeText(this,
+                                "Folder \"" + name + "\" created",
+                                Toast.LENGTH_SHORT).show();
+                        // TODO: persist folder and associate selected apps
+                    }
+                })
+                .setNegativeButton(android.R.string.cancel, null)
+                .show();
+    }
+
+    // =========================================================================
+    // GridView adapter
+    // =========================================================================
+
+    private static class AppGridAdapter extends BaseAdapter {
+        private final Context context;
+        private final List<AppPojo> apps;
+
+        AppGridAdapter(Context context, List<AppPojo> apps) {
+            this.context = context;
+            this.apps = apps;
+        }
+
+        @Override public int getCount() { return apps.size(); }
+        @Override public Object getItem(int pos) { return apps.get(pos); }
+        @Override public long getItemId(int pos) { return pos; }
+
+        @Override
+        public View getView(int position, View convertView, ViewGroup parent) {
+            if (convertView == null) {
+                convertView = LayoutInflater.from(context)
+                        .inflate(R.layout.item_app_drawer_cell, parent, false);
+            }
+            AppPojo app = apps.get(position);
+            ImageView icon = convertView.findViewById(R.id.drawer_cell_icon);
+            TextView label = convertView.findViewById(R.id.drawer_cell_label);
+
+            label.setText(app.getName());
+            try {
+                Drawable d = KissApplication.getApplication(context).getIconsHandler()
+                        .getDrawableIconForPackage(app.getComponent(), app.userHandle);
+                icon.setImageDrawable(d);
+            } catch (Exception ignored) {
+                icon.setImageResource(android.R.drawable.sym_def_app_icon);
+            }
+
+            convertView.setOnClickListener(v -> {
+                try {
+                    LauncherApps launcherApps =
+                            ContextCompat.getSystemService(context, LauncherApps.class);
+                    if (launcherApps != null) {
+                        launcherApps.startMainActivity(app.getComponent(),
+                                app.userHandle.getRealHandle(), null, null);
+                    }
+                } catch (Exception e) {
+                    Toast.makeText(context, R.string.application_not_found,
+                            Toast.LENGTH_SHORT).show();
+                }
+            });
+
+            return convertView;
+        }
+    }
+}

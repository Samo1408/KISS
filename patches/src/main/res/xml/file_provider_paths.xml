<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider paths required for sharing APK files.
    Referenced by AndroidManifest.xml provider declaration.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Share APKs from the app's public source directory -->
    <root-path
        name="root"
        path="/" />
    <external-path
        name="external"
        path="." />
    <files-path
        name="files"
        path="." />
    <cache-path
        name="cache"
        path="." />
</paths>
